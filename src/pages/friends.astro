---
/**
 * friends.astro — Friends page.
 *
 * Reads the `friends[]` array from src/content/pages/friends.md frontmatter
 * and renders it via FriendsGrid (shuffled, lazy-loaded avatar cards).
 * Mirrors Hugo's /friends/ page served by diary's friends-list shortcode.
 */

import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import FriendsGrid from "../components/FriendsGrid.astro";
import Comments from "../components/Comments.astro";

interface Friend {
  name: string;
  href: string;
  desc?: string;
  qq?: string;
  hash?: string;
  email?: string;
  icon?: string;
}

const pages = await getCollection("pages");
const friendsPage = pages.find(
  (p) => p.id === "friends.md" || p.data.slug === "friends",
);

// friends[] lives in frontmatter; the Zod schema doesn't define it, so
// it is stripped from p.data. We access it via the raw entry body isn't
// enough — we need to reach into the loader's raw data. In Astro 5 content
// layer with glob(), unrecognised frontmatter fields are accessible on the
// entry itself as entry.data is the Zod-parsed output only.
// The friends list is stored in the content file's YAML frontmatter as
// `friends[]`. Since it's not in our schema it gets dropped by Zod.
// We re-parse via the filePath if available, otherwise fall back to empty.
//
// Practical workaround: extend the Zod schema or read raw via import.meta.glob.
// Here we use import.meta.glob to get the raw frontmatter without Zod stripping.
const rawPages = import.meta.glob<{ frontmatter: Record<string, unknown> }>(
  "/src/content/pages/friends.md",
  { eager: true },
);
const rawFriends = Object.values(rawPages)[0]?.frontmatter?.friends as
  | Friend[]
  | undefined;
const friends: Friend[] = rawFriends ?? [];

// Body prose from the friends.md content (intro paragraph above the list)
const { Content } = friendsPage ? await render(friendsPage) : { Content: null };
---

<BaseLayout title="朋友们" description="博主的朋友们">
  {
    /* Mirror diary single.html: text-only title head + shadowed body card.
      friends.md sets disableMetaInfo, so the head shows only the title. */
  }
  <div class="post-list-container post-list-container-shadow">
    <div class="post friends-page">
      <div class="post-head-wrapper-text-only">
        <div class="post-title">朋友们</div>
      </div>
      <div class="post-body-wrapper">
        <div class="post-body">
          {Content && <Content />}
          <FriendsGrid friends={friends} />
        </div>
      </div>

      {
        /* Comment section — mirrors diary single.html (friends.md doesn't disable comments) */
      }
      <Comments />
    </div>
  </div>
</BaseLayout>

{/* Lazy Artalk mount on viewport enter / click */}
<script>
  import { initComments } from "../scripts/comments";

  document.addEventListener("DOMContentLoaded", () => {
    initComments();
  });
</script>
