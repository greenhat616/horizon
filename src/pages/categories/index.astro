---
/**
 * categories/index.astro — All categories listing page.
 *
 * Collects every unique category from published posts, shows each
 * with its article count. Mirrors Hugo's taxonomy list page at /categories/.
 *
 * Links use urlizeTerm() to match the routes generated by [category].astro.
 */

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { urlizeTerm } from '../../lib/taxonomy';

const allPosts = await getCollection('posts');
const published = allPosts.filter((p) => !p.data.draft && !p.data.hidden);

// Build urlized-slug → { label, count } map
// When multiple raw terms share a slug, the first encountered wins as label.
const catMap = new Map<string, { label: string; count: number }>();
for (const post of published) {
  for (const rawCat of post.data.categories ?? []) {
    const slug = urlizeTerm(rawCat);
    if (!catMap.has(slug)) {
      catMap.set(slug, { label: rawCat, count: 0 });
    }
    catMap.get(slug)!.count += 1;
  }
}

// Sort by count descending, then alphabetically by slug
const categories = [...catMap.entries()].sort(
  (a, b) => b[1].count - a[1].count || a[0].localeCompare(b[0])
);
---

<BaseLayout title="分类" description="所有分类">
  <div class="post-list-container post-list-container-no-background">
    <div class="taxonomy-header">
      <h1>分类</h1>
    </div>
    <div class="taxonomy-list">
      {categories.map(([slug, { label, count }]) => (
        <a href={`/categories/${slug}/`} class="taxonomy-item">
          <span class="taxonomy-name">{label}</span>
          <span class="taxonomy-count">{count}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
