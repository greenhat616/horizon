---
/**
 * index.astro — Site home page (post list, page 1).
 *
 * Mirrors diary's layouts/index.html: exclude hidden posts, sort by date
 * descending, paginate. The home page URL is / and pagination continues
 * at /posts/page/N/.
 *
 * isHome=true suppresses the title prefix so BaseLayout renders the
 * bare site title.
 */

import { getCollection } from 'astro:content';
import ListLayout from '../layouts/ListLayout.astro';
import { toCardData } from '../lib/post-card';
import { isListable } from '../lib/posts';

const PAGE_SIZE = 10;

const allPosts = (await getCollection('posts')).filter(isListable);

const sorted = allPosts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const totalPages = Math.max(1, Math.ceil(sorted.length / PAGE_SIZE));
const pagePosts = sorted.slice(0, PAGE_SIZE);

const posts = await Promise.all(pagePosts.map(toCardData));
---

<ListLayout
  isHome={true}
  posts={posts}
  page={1}
  totalPages={totalPages}
  nextUrl={totalPages > 1 ? '/posts/page/2/' : undefined}
/>
