---
/**
 * posts/[...id].astro — Single post detail route.
 *
 * Uses post.data.slug as the URL segment (lowercase, matches production
 * sitemap). Never uses post.id which is derived from the Chinese filename.
 *
 * Generates:  /posts/<slug>/
 * prev/next:  adjacent posts by date (prev = older, next = newer).
 */

import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { isListable, postSlug } from '../../lib/posts';

export async function getStaticPaths() {
  const allPosts = (await getCollection('posts')).filter(isListable);

  // Sort descending by date (newest first = index 0)
  const sorted = allPosts.sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
  );

  return sorted.map((post, index) => {
    // "newer" post is at lower index; "older" post is at higher index.
    // PostLayout convention: nextHref = newer, prevHref = older.
    const newerPost = index > 0 ? sorted[index - 1] : undefined;
    const olderPost = index < sorted.length - 1 ? sorted[index + 1] : undefined;

    return {
      params: { id: postSlug(post) },
      props: {
        post,
        prevHref: olderPost ? `/posts/${postSlug(olderPost)}/` : undefined,
        prevTitle: olderPost?.data.title,
        nextHref: newerPost ? `/posts/${postSlug(newerPost)}/` : undefined,
        nextTitle: newerPost?.data.title,
      },
    };
  });
}

const { post, prevHref, prevTitle, nextHref, nextTitle } = Astro.props;
const { data } = post;

const { Content, headings: rawHeadings, remarkPluginFrontmatter } = await render(post);

// remark-gfm appends a visually-hidden <h2 id="footnote-label">Footnotes</h2>
// to articles that use footnotes. It is not authored content, so drop it from
// the ToC (Goldmark never emitted it, so production never listed it).
const headings = rawHeadings.filter((h) => h.slug !== 'footnote-label');

// remark-reading-time-cjk writes the reading time in seconds (Hugo's formula).
const rawReadingSeconds = remarkPluginFrontmatter?.readingSeconds as number | undefined;
const readingSeconds =
  typeof rawReadingSeconds === 'number' ? rawReadingSeconds : undefined;

// Effective lastmod: explicit frontmatter wins, then git-derived lastModified
// from the remark plugin (exposed via remarkPluginFrontmatter after render()).
const gitLastModified = remarkPluginFrontmatter?.lastModified as string | undefined;
const effectiveLastmod: Date | undefined =
  data.lastmod ??
  data.updated ??
  (gitLastModified ? new Date(gitLastModified) : undefined);
---

<PostLayout
  title={data.title}
  description={data.description ?? undefined}
  date={data.date}
  lastmod={effectiveLastmod}
  categories={data.categories ?? []}
  tags={data.tags ?? []}
  readingSeconds={readingSeconds}
  featuredImage={data.featured_image ?? undefined}
  headings={headings}
  enableLaTeX={data.enableLaTeX}
  disableToC={data.disableToC ?? false}
  disableMetaInfo={data.disableMetaInfo ?? false}
  disablePagination={data.disablePagination ?? false}
  disableCC={data.disableCC ?? false}
  disableOutdatedNotice={(data as { disableOutdatedNotice?: boolean }).disableOutdatedNotice ?? false}
  comment={data.comment}
  draft={data.draft}
  prevHref={prevHref}
  prevTitle={prevTitle}
  nextHref={nextHref}
  nextTitle={nextTitle}
>
  <Content />
</PostLayout>
