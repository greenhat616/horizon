---
/**
 * tags/index.astro — All tags listing page.
 *
 * Collects every unique tag from published posts, shows each tag
 * with its article count. Mirrors Hugo's taxonomy list page at /tags/.
 *
 * Links use urlizeTerm() to match the routes generated by [tag].astro.
 */

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { urlizeTerm } from '../../lib/taxonomy';

const allPosts = await getCollection('posts');
const published = allPosts.filter((p) => !p.data.draft && !p.data.hidden);

// Build urlized-slug → { label, count } map
// When multiple raw terms share a slug, the first encountered wins as label.
const tagMap = new Map<string, { label: string; count: number }>();
for (const post of published) {
  for (const rawTag of post.data.tags ?? []) {
    const slug = urlizeTerm(rawTag);
    if (!tagMap.has(slug)) {
      tagMap.set(slug, { label: rawTag, count: 0 });
    }
    tagMap.get(slug)!.count += 1;
  }
}

// Sort tags by count descending, then alphabetically by slug
const tags = [...tagMap.entries()].sort(
  (a, b) => b[1].count - a[1].count || a[0].localeCompare(b[0])
);
---

<BaseLayout title="标签" description="所有标签">
  {/* Mirror diary single.html: text-only title head + shadowed body card. */}
  <div class="post-list-container post-list-container-shadow">
    <div class="post archive-page">
      <div class="post-head-wrapper-text-only">
        <div class="post-title">标签</div>
      </div>
      <div class="post-body-wrapper">
        <div class="post-body">
          <p class="mt-0! mb-6! text-[0.95em] text-[#000e14]/55 dark:text-white/45">
            共 {tags.length} 个标签
          </p>
          <div class="flex flex-wrap gap-2.5">
            {tags.map(([slug, { label, count }]) => (
              <a
                href={`/tags/${slug}/`}
                class="group inline-flex items-center gap-2 rounded-full border px-3.5 py-1.5 text-[0.95rem] leading-none no-underline transition-colors border-[#01506f]/15 bg-[#01506f]/[0.05] text-[#01506f] hover:border-[#01506f]/45 hover:bg-[#01506f]/12 dark:border-white/15 dark:bg-white/8 dark:text-[#a9d6ea]! dark:hover:border-[#a9d6ea]/40 dark:hover:bg-white/12"
              >
                <span class="text-[#01506f] dark:text-[#a9d6ea]!">{label}</span>
                <span class="inline-flex h-5 min-w-5 items-center justify-center rounded-full px-1.5 text-xs font-semibold tabular-nums transition-colors bg-[#01506f]/12 text-[#01506f]! group-hover:bg-[#01506f]/20 dark:bg-white/12 dark:text-[#a9d6ea]! dark:group-hover:bg-white/18">
                  {count}
                </span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
