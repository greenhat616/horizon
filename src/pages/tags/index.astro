---
/**
 * tags/index.astro — All tags listing page.
 *
 * Collects every unique tag from published posts, shows each tag
 * with its article count. Mirrors Hugo's taxonomy list page at /tags/.
 *
 * Links use urlizeTerm() to match the routes generated by [tag].astro.
 */

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { urlizeTerm } from '../../lib/taxonomy';

const allPosts = await getCollection('posts');
const published = allPosts.filter((p) => !p.data.draft && !p.data.hidden);

// Build urlized-slug → { label, count } map
// When multiple raw terms share a slug, the first encountered wins as label.
const tagMap = new Map<string, { label: string; count: number }>();
for (const post of published) {
  for (const rawTag of post.data.tags ?? []) {
    const slug = urlizeTerm(rawTag);
    if (!tagMap.has(slug)) {
      tagMap.set(slug, { label: rawTag, count: 0 });
    }
    tagMap.get(slug)!.count += 1;
  }
}

// Sort tags by count descending, then alphabetically by slug
const tags = [...tagMap.entries()].sort(
  (a, b) => b[1].count - a[1].count || a[0].localeCompare(b[0])
);
---

<BaseLayout title="标签" description="所有标签">
  <div class="post-list-container post-list-container-no-background">
    <div class="taxonomy-header">
      <h1>标签</h1>
    </div>
    <div class="taxonomy-list">
      {tags.map(([slug, { label, count }]) => (
        <a href={`/tags/${slug}/`} class="taxonomy-item">
          <span class="taxonomy-name">{label}</span>
          <span class="taxonomy-count">{count}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
