---
/**
 * PostMeta.astro — Post metadata row (date, categories, reading time).
 * Mirrors diary's partials/post-item-meta.html and the .post-meta block
 * inside single.html.
 *
 * Every part except the date is optional and toggleable, so the list card can
 * show only "date · reading time" (matching i.a632079.me) while the article
 * header keeps the full row. The date is always rendered.
 *
 * Props
 *   date            — publish date (required, always shown)
 *   categories      — array of category strings
 *   tags            — array of tag strings
 *   readingSeconds  — reading time in seconds (from remark-reading-time-cjk),
 *                     rendered as Hugo's "min s" string
 *   draft           — show draft badge when true
 *   variant         — 'item' (list card) | 'post' (article header, default)
 *   showCategories  — render categories (default: post only)
 *   showTags        — render tags (default: post only)
 *   showReadingTime — render reading time (default: true)
 *   dateStyle       — 'cn' (2026年6月20日) | 'dash' (2026-06-20)
 *                     (default: 'dash' for item, 'cn' for post)
 */
import { formatDate, formatDateDash } from '../lib/dates';
import { formatReadingTime } from '../lib/reading-time';
import { urlizeTerm } from '../lib/taxonomy';

interface Props {
  date: Date;
  categories?: string[];
  tags?: string[];
  readingSeconds?: number;
  draft?: boolean;
  variant?: 'item' | 'post';
  showCategories?: boolean;
  showTags?: boolean;
  showReadingTime?: boolean;
  dateStyle?: 'cn' | 'dash';
}

const {
  date,
  categories = [],
  tags = [],
  readingSeconds,
  draft = false,
  variant = 'post',
  showCategories = variant === 'post',
  showTags = variant === 'post',
  showReadingTime = true,
  dateStyle = variant === 'item' ? 'dash' : 'cn',
} = Astro.props;

const formattedDate =
  dateStyle === 'dash' ? formatDateDash(date) : formatDate(date);
const cssClass = variant === 'item' ? 'post-item-meta' : 'post-meta';

// Reading time rendered exactly as the Hugo diary theme: "24 min 30 s".
const readingTimeText =
  readingSeconds != null ? formatReadingTime(readingSeconds) : '';
---

<div class={cssClass}>
  <time itemprop="datePublished" datetime={date.toISOString()}>
    {formattedDate}
  </time>

  {showCategories && categories.length > 0 && (
    <>
      &emsp;
      <i class="material-icons">folder</i>
      {categories.map((cat) => (
        <a href={`/categories/${urlizeTerm(cat)}/`}>{cat}</a>
      ))}
    </>
  )}

  {showTags && tags.length > 0 && (
    <>
      &emsp;
      <i class="material-icons">label</i>
      {tags.map((tag, i) => (
        <>
          <a href={`/tags/${urlizeTerm(tag)}/`}>{tag}</a>
          {i < tags.length - 1 && <> </>}
        </>
      ))}
    </>
  )}

  {showReadingTime && readingSeconds != null && (
    <>
      &emsp;
      <i class="material-icons">schedule</i>
      {readingTimeText}
    </>
  )}

  {draft && (
    <>
      &emsp;
      <span class="draft-label">草稿</span>
    </>
  )}
</div>

<style>
  /* Inline amber pill — visually consistent with DraftBadge. Used as the
     fallback draft indicator on cards/headers with no featured image to
     anchor the corner badge to. */
  .draft-label {
    display: inline-block;
    padding: 0 8px;
    border-radius: 999px;
    font-size: 12px;
    line-height: 1.7;
    font-weight: 600;
    color: #fff;
    background: rgba(217, 119, 6, 0.92); /* amber-600 */
    vertical-align: middle;
  }

  :global(html.night) .draft-label {
    background: rgba(245, 158, 11, 0.92); /* amber-500 */
    color: #1a1a1a;
  }
</style>
