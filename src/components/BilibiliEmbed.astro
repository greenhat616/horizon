---
/**
 * BilibiliEmbed.astro — Responsive Bilibili video embed.
 * Mirrors diary's shortcodes/bilibili.html.
 * 16:9 aspect ratio via padding-bottom trick.
 *
 * Props
 *   bvid — Bilibili BV ID (e.g. "BV1xx411c7mD")
 *   page — playlist page number (default 1)
 */

interface Props {
  bvid: string;
  page?: number;
}

const { bvid, page = 1 } = Astro.props;

const src = `//player.bilibili.com/player.html?bvid=${bvid}&page=${page}&autoplay=0`;
---

<div style="position:relative; padding-bottom:56.25%; width:100%; height:0">
  <iframe
    src={src}
    allowfullscreen={true}
    style="position:absolute; height:100%; width:100%; border:none;"
    title={`Bilibili video ${bvid}`}></iframe>
</div>
