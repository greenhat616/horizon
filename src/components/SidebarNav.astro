---
/**
 * SidebarNav.astro — Desktop fixed sidebar.
 *
 * Replicates themes/diary/layouts/partials/sidebar.html.
 * DOM class names match journal.scss so existing styles apply automatically:
 *   #sideContainer.side-container → .nav-head → .nav-title / .nav-subtitle
 *   .nav-link-list → .nav-link-item (active class on match)
 *   .nav-footer
 *
 * Title, subtitle, copyright and nav items come from the single site config
 * (site.config.ts → defineSiteConfig); nav is pre-sorted by weight there.
 */

import site from "../../site.config";

const {
  title: SITE_TITLE,
  subtitle: SITE_SUBTITLE,
  copyright: SITE_COPYRIGHT,
  nav: NAV_ITEMS,
} = site;

interface Props {
  /** Current page pathname — used to highlight the active nav item. */
  pathname?: string;
}

const { pathname = "/" } = Astro.props;

/** True when the current path starts with the nav item's URL prefix. */
function isActive(itemUrl: string): boolean {
  if (!itemUrl.startsWith("/")) return false; // external links never active
  return pathname === itemUrl || pathname.startsWith(itemUrl);
}
---

<div id="sideContainer" class="side-container">
  {/* Site title / home link — mirrors sidebar.html nav-head */}
  <a
    class:list={[
      "a-block",
      "nav-head",
      isActive("/") && pathname === "/" ? "active" : "false",
    ]}
    href="/"
  >
    <div class="nav-title">{SITE_TITLE}</div>
    {SITE_SUBTITLE && <div class="nav-subtitle">{SITE_SUBTITLE}</div>}
  </a>

  <div class="nav-link-list">
    {
      NAV_ITEMS.map((item) => (
        <a
          class:list={[
            "a-block",
            "nav-link-item",
            isActive(item.url) ? "active" : "false",
          ]}
          href={item.url}
          target={item.url.startsWith("http") ? "_blank" : undefined}
          rel={item.url.startsWith("http") ? "noopener noreferrer" : undefined}
        >
          {item.name}
        </a>
      ))
    }
  </div>

  {
    /* No dark-mode toggle here: the original diary sidebar.html had none.
      The desktop toggle lives in the right-side ExtraBar; mobile uses MobileHeader. */
  }
  <div class="nav-footer">
    {
      /* Mirrors copyright.html — preserve attribution per MIT licence requirement */
    }
    Design based on <a href="https://github.com/amazingrise/hugo-theme-diary"
      >Diary</a
    > by{" "}
    <a href="https://risehere.net">Rise</a> &amp; <a href="https://i.a632079.me"
      >a632079</a
    >
    <br />
    Ported from <a
      href="https://mak1t0.cc/"
      target="_blank"
      rel="noreferrer noopener">Makito</a
    >
    <br />
    &copy; {SITE_COPYRIGHT}
    <br />
    <a
      href="https://beian.miit.gov.cn/"
      target="_blank"
      rel="noreferrer noopener">苏ICP备17002503号</a
    >
  </div>
</div>
