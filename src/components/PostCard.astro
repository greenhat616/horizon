---
/**
 * PostCard.astro — List item card for the home/taxonomy pages.
 * Mirrors diary's layouts/index.html post-item structure.
 *
 * Props
 *   href         — URL to the post
 *   title        — post title
 *   summary      — excerpt or description text
 *   featuredImage — URL string (remote CDN or relative)
 *   date         — publish date
 *   categories   — array of category strings
 *   tags         — array of tag strings
 *   readingSeconds — reading time in seconds (optional)
 *   draft        — show draft badge (optional)
 */
import PostMeta from './PostMeta.astro';

/** Optional overrides for the meta row; see PostMeta for defaults. */
export interface MetaOptions {
  showCategories?: boolean;
  showTags?: boolean;
  showReadingTime?: boolean;
  dateStyle?: 'cn' | 'dash';
}

interface Props {
  href: string;
  title: string;
  summary?: string;
  featuredImage?: string | null;
  date: Date;
  categories?: string[];
  tags?: string[];
  readingSeconds?: number;
  draft?: boolean;
  metaOptions?: MetaOptions;
}

const {
  href,
  title,
  summary,
  featuredImage,
  date,
  categories = [],
  tags = [],
  readingSeconds,
  draft = false,
  metaOptions = {},
} = Astro.props;
---

<a href={href} class="a-block">
  <div class="post-item-wrapper">
    <div class="post-item post-item-no-divider">
      <div class="post-item-info-wrapper">
        <div class="post-item-title">{title}</div>
        {summary && (
          <div class="post-item-summary">{summary}</div>
        )}
        <PostMeta
          date={date}
          categories={categories}
          tags={tags}
          readingSeconds={readingSeconds}
          draft={draft}
          variant="item"
          {...metaOptions}
        />
      </div>

      {featuredImage && (
        <div class="post-item-image-wrapper">
          <div class="post-item-image">
            <div
              class="post-item-image-inner"
              style={`background-image: url('${featuredImage}')`}
            />
          </div>
        </div>
      )}
    </div>
  </div>
</a>
