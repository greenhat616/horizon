---
/**
 * Footer.astro — Mobile footer (copyright + paginator row).
 *
 * Replicates themes/diary/layouts/partials/mobile-footer.html
 * and partials/copyright.html.
 *
 * Shown only on mobile (≤ $single-column-max-width = 1020px) via
 * journal.scss — desktop copyright lives inside SidebarNav.
 *
 * Props:
 *   prevUrl — href for previous-page link (list pages)
 *   nextUrl — href for next-page link (list pages)
 */

interface Props {
  prevUrl?: string;
  nextUrl?: string;
}

const { prevUrl, nextUrl } = Astro.props;

// TODO: 后续从 config 注入
const SITE_COPYRIGHT = '2026 a632079';
---

{/* Mobile paginator row — mirrors mobile-paginator.html behaviour */}
{(prevUrl || nextUrl) && (
  <div class="mobile-paginator">
    {prevUrl
      ? <a class="mobile-paginator-action" href={prevUrl} aria-label="上一页">
          <i class="material-icons" aria-hidden="true">chevron_left</i>
        </a>
      : <span class="mobile-paginator-action mobile-paginator-action--disabled" aria-hidden="true">
          <i class="material-icons" aria-hidden="true">chevron_left</i>
        </span>
    }
    {nextUrl
      ? <a class="mobile-paginator-action" href={nextUrl} aria-label="下一页">
          <i class="material-icons" aria-hidden="true">chevron_right</i>
        </a>
      : <span class="mobile-paginator-action mobile-paginator-action--disabled" aria-hidden="true">
          <i class="material-icons" aria-hidden="true">chevron_right</i>
        </span>
    }
  </div>
)}

{/* Copyright — mirrors copyright.html; preserve attribution per MIT licence */}
<div id="single-column-footer">
  Hugo Theme <a href="https://github.com/amazingrise/hugo-theme-diary">Diary</a> by{' '}
  <a href="https://risehere.net">Rise</a> &amp; <a href="https://i.a632079.me">a632079</a>
  <br />
  Ported from <a href="https://mak1t0.cc/" target="_blank" rel="noreferrer noopener">Makito</a>
  <br />
  &copy; {SITE_COPYRIGHT}
  <br />
  <a href="https://beian.miit.gov.cn/" target="_blank" rel="noreferrer noopener">苏ICP备17002503号</a>
</div>

<style>
  /*
   * #single-column-footer's mobile-only visibility is handled by
   * journal.scss. The paginator row is a sibling, so it must mirror
   * the same gating itself: hidden by default, shown only at/below
   * $single-column-max-width (1020px). Otherwise it leaks onto desktop.
   */
  .mobile-paginator {
    display: none;
    align-items: center;
    justify-content: space-between;
    padding: 8px 16px;
  }

  @media screen and (max-width: 1020px) {
    .mobile-paginator {
      display: flex;
    }
  }

  .mobile-paginator-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    text-decoration: none;
    color: inherit;
  }

  .mobile-paginator-action--disabled {
    opacity: 0.3;
    pointer-events: none;
  }
</style>
