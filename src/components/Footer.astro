---
/**
 * Footer.astro — Mobile footer (paginator + copyright).
 *
 * Replicates themes/diary/layouts/partials/mobile-footer.html, which renders
 *   partial "mobile-paginator.html"   → .pagination (page X/Y, mobile only)
 *   #single-column-footer             → copyright
 * as direct children of #app, OUTSIDE .stream-container.
 *
 * Keeping the paginator here (not inline after the list) mirrors the original
 * theme and is what prevents the list's last card from inheriting a stray
 * divider — see journal.scss `.post-list-container > *:not(:last-child)`.
 *
 * Both children are mobile-only and self-gate via journal.scss:
 *   .pagination          → display:none desktop / flex ≤1020px
 *   #single-column-footer → display:none desktop / block ≤1020px
 * (desktop copyright + pagination live in SidebarNav / ExtraBar instead.)
 *
 * Props:
 *   prevUrl    — href for previous-page link (list pages)
 *   nextUrl    — href for next-page link (list pages)
 *   page       — current page number (list pages)
 *   totalPages — total page count (list pages; paginator hidden when ≤ 1)
 */

import PostPager from "./PostPager.astro";

interface Props {
  prevUrl?: string;
  nextUrl?: string;
  page?: number;
  totalPages?: number;
}

const { prevUrl, nextUrl, page = 1, totalPages = 1 } = Astro.props;

// TODO: 后续从 config 注入
const SITE_COPYRIGHT = "2026 a632079";
---

{/* Mobile paginator (page X/Y) — mirrors mobile-paginator.html */}
<PostPager
  variant="list"
  page={page}
  totalPages={totalPages}
  prevHref={prevUrl}
  nextHref={nextUrl}
/>

{/* Copyright — mirrors copyright.html; preserve attribution per MIT licence */}
<div id="single-column-footer">
  Design based on <a href="https://github.com/amazingrise/hugo-theme-diary"
    >Diary</a
  > by{" "}
  <a href="https://risehere.net">Rise</a> &amp; <a href="https://i.a632079.me"
    >a632079</a
  >
  <br />
  Ported from <a
    href="https://mak1t0.cc/"
    target="_blank"
    rel="noreferrer noopener">Makito</a
  >
  <br />
  &copy; {SITE_COPYRIGHT}
  <br />
  <a href="https://beian.miit.gov.cn/" target="_blank" rel="noreferrer noopener"
    >苏ICP备17002503号</a
  >
</div>
