---
/**
 * Notice.astro — Info/warning/note/tip notice box.
 * Mirrors diary's shortcodes/notice.html.
 *
 * Styling is now ENCAPSULATED in this component's scoped <style> block
 * (Tailwind v4 utilities via `@reference "tailwindcss"` + `@apply`, plus the
 * theme's custom hex colors). Previously these `.notice*` rules lived in the
 * diary theme's inline <style> (extended_head.html) — the sole owner is now
 * this component. OutdatedNotice.astro composes <Notice> to inherit them.
 *
 * SVG icon sprites are inlined once per render.
 *
 * Props
 *   type — 'info' | 'warning' | 'note' | 'tip'
 *   id   — optional HTML id for anchor links
 *   …rest — any extra HTML attributes (data-*, hidden, …) are spread onto the
 *           root .notice element (used by OutdatedNotice for its data-* contract).
 *
 * Usage:
 *   <Notice type="info">内容 Markdown 在这里</Notice>
 */

type NoticeType = "info" | "warning" | "note" | "tip";

interface Props {
  type: NoticeType;
  id?: string;
  /** Extra HTML attributes spread onto the root .notice element. */
  [key: string]: unknown;
}

const { type, id, ...rest } = Astro.props;

// Chinese labels matching diary i18n keys
const labels: Record<NoticeType, string> = {
  info: "注意",
  warning: "警告",
  note: "笔记",
  tip: "提示",
};

const label = labels[type] ?? "注意";
---

{
  /* SVG sprite — inlined so the <use> hrefs work without an extra HTTP request */
}
<svg
  display="none"
  height="0"
  id="notice_figure"
  width="0"
  xmlns="http://www.w3.org/2000/svg"
>
  <symbol
    id="tip-notice"
    preserveAspectRatio="xMidYMid meet"
    viewBox="0 0 512 512"
  >
    <path
      d="M504 256c0 136.967-111.033 248-248 248S8 392.967 8 256 119.033 8 256 8s248 111.033 248 248zM227.314 387.314l184-184c6.248-6.248 6.248-16.379 0-22.627l-22.627-22.627c-6.248-6.249-16.379-6.249-22.628 0L216 308.118l-70.059-70.059c-6.248-6.248-16.379-6.248-22.628 0l-22.627 22.627c-6.248 6.248-6.248 16.379 0 22.627l104 104c6.249 6.249 16.379 6.249 22.628.001z"
      style="fill: var(--icon-color)"></path>
  </symbol>
  <symbol
    id="note-notice"
    preserveAspectRatio="xMidYMid meet"
    viewBox="0 0 512 512"
  >
    <path
      d="M504 256c0 136.997-111.043 248-248 248S8 392.997 8 256C8 119.083 119.043 8 256 8s248 111.083 248 248zm-248 50c-25.405 0-46 20.595-46 46s20.595 46 46 46 46-20.595 46-46-20.595-46-46-46zm-43.673-165.346l7.418 136c.347 6.364 5.609 11.346 11.982 11.346h48.546c6.373 0 11.635-4.982 11.982-11.346l7.418-136c.375-6.874-5.098-12.654-11.982-12.654h-63.383c-6.884 0-12.356 5.78-11.981 12.654z"
      style="fill: var(--icon-color)"></path>
  </symbol>
  <symbol
    id="warning-notice"
    preserveAspectRatio="xMidYMid meet"
    viewBox="0 0 576 512"
  >
    <path
      d="M569.517 440.013C587.975 472.007 564.806 512 527.94 512H48.054c-36.937 0-59.999-40.055-41.577-71.987L246.423 23.985c18.467-32.009 64.72-31.951 83.154 0l239.94 416.028zM288 354c-25.405 0-46 20.595-46 46s20.595 46 46 46 46-20.595 46-46-20.595-46-46-46zm-43.673-165.346l7.418 136c.347 6.364 5.609 11.346 11.982 11.346h48.546c6.373 0 11.635-4.982 11.982-11.346l7.418-136c.375-6.874-5.098-12.654-11.982-12.654h-63.383c-6.884 0-12.356 5.78-11.981 12.654z"
      style="fill: var(--icon-color)"></path>
  </symbol>
  <symbol
    id="info-notice"
    preserveAspectRatio="xMidYMid meet"
    viewBox="0 0 512 512"
  >
    <path
      d="M256 8C119.043 8 8 119.083 8 256c0 136.997 111.043 248 248 248s248-111.003 248-248C504 119.083 392.957 8 256 8zm0 110c23.196 0 42 18.804 42 42s-18.804 42-42 42-42-18.804-42-42 18.804-42 42-42zm56 254c0 6.627-5.373 12-12 12h-88c-6.627 0-12-5.373-12-12v-24c0-6.627 5.373-12 12-12h12v-64h-12c-6.627 0-12-5.373-12-12v-24c0-6.627 5.373-12 12-12h64c6.627 0 12 5.373 12 12v100h12c6.627 0 12 5.373 12 12v24z"
      style="fill: var(--icon-color)"></path>
  </symbol>
</svg>

<div class={`notice ${type}`} id={id} {...rest}>
  <p class="first notice-title">
    <span class="icon-notice baseline">
      <svg><use href={`#${type}-notice`}></use></svg>
    </span>
    {label}
  </p>
  <slot />
</div>

<style>
  /* Tailwind v4: required so @apply resolves inside a scoped component style. */
  @reference "tailwindcss";

  /* Layout/spacing/typography → Tailwind utilities.
     Theme palette → diary's original hex values (porting these to arbitrary
     Tailwind values would only add noise). */
  .notice {
    @apply mb-6 p-4.5 leading-6;
    color: #444;
    background: #e7f2fa;
  }

  /* Slotted markdown paragraphs are not under this component's scope, so the
     descendant selector must reach them with :global(). */
  .notice :global(p:last-child) {
    @apply mb-0;
  }

  .notice-title {
    @apply -mx-4.5 -mt-4.5 mb-3 flex items-center px-4.5 py-1 font-bold text-white;
    background: #6ab0de;
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue",
      Arial, "Noto Sans", sans-serif, "Apple Color Emoji", "Segoe UI Emoji",
      "Segoe UI Symbol", "Noto Color Emoji";
  }

  .notice-title * {
    --icon-color: #fff;
    @apply text-white;
  }

  .notice.warning .notice-title {
    background: rgba(217, 83, 79, 0.9);
  }
  .notice.warning {
    background: #fae2e2;
  }

  .notice.info .notice-title {
    background: #f0b37e;
  }
  .notice.info {
    background: #fff2db;
  }

  .notice.note .notice-title {
    background: #6ab0de;
  }
  .notice.note {
    background: #e7f2fa;
  }

  .notice.tip .notice-title {
    background: rgba(92, 184, 92, 0.8);
  }
  .notice.tip {
    background: #e6f9e6;
  }

  .icon-notice {
    @apply mr-2 inline-flex self-center;
  }
  .icon-notice img,
  .icon-notice svg {
    @apply h-[1em] w-[1em];
    fill: currentColor;
    /* Optical centering: `.notice-title` is `flex items-center`, so the icon is
       centered geometrically. CJK glyphs sit slightly high within the em box,
       so a geometrically-centered icon reads as too high — nudge it down by a
       small fraction (much less than the old 0.125em inline-baseline value). */
    transform: translateY(0.05em);
  }

  /* Dark mode — html.night lives outside this component's scope. */
  :global(html.night) .notice.info {
    background: #373737;
  }
  :global(html.night) .notice.info .notice-title {
    background: #e17d25;
  }
</style>
