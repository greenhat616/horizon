---
/**
 * MobileDrawer.astro — Mobile slide-in navigation drawer.
 *
 * Replicates the .single-column-drawer-container portion of
 * themes/diary/layouts/partials/mobile-header.html.
 *
 * DOM contracts (required by src/scripts/nav.ts):
 *   [data-drawer]  — the drawer element; nav.ts toggles .is-open on this
 *
 * The drawer backdrop click-to-close is handled by nav.ts's initDrawer().
 * Class names match journal.scss (same contract as the original Vue theme):
 *   .single-column-drawer-container  (+ .single-column-drawer-container-active when open)
 *   .single-column-drawer-mask       — added to the backdrop ONLY while open
 *                                       (the class itself makes the mask visible;
 *                                        journal.scss forces display:block!important)
 *   .drawer-content → .drawer-menu → .drawer-menu-item (+ .active)
 *
 * Nav items come from the single site config (site.config.ts), pre-sorted by
 * weight — same list as the desktop SidebarNav.
 */

import site from "../../site.config";

const { nav: NAV_ITEMS } = site;

interface Props {
  /** Current page pathname — used to highlight the active nav item. */
  pathname?: string;
}

const { pathname = "/" } = Astro.props;

function isActive(itemUrl: string): boolean {
  if (!itemUrl.startsWith("/")) return false;
  return pathname === itemUrl || pathname.startsWith(itemUrl);
}
---

{/* Slide-in drawer — nav.ts toggles .is-open */}
<div
  data-drawer
  id="drawer"
  class="single-column-drawer-container"
  aria-hidden="true"
>
  <div class="drawer-content">
    <div class="drawer-menu">
      {
        NAV_ITEMS.map((item) => (
          <a
            class:list={[
              "a-block",
              "drawer-menu-item",
              isActive(item.url) ? "active" : "false",
            ]}
            href={item.url}
            target={item.url.startsWith("http") ? "_blank" : undefined}
            rel={
              item.url.startsWith("http") ? "noopener noreferrer" : undefined
            }
          >
            {item.name}
          </a>
        ))
      }
      {
        /* ToC slot — PostLayout fills this via a portal or separate component */
      }
    </div>
  </div>
</div>

{
  /* Backdrop — nav.ts adds .single-column-drawer-mask while the drawer is open
    (the class makes it visible) and removes it on close / backdrop click.
    Rendered class-less so it stays invisible by default. */
}
<div id="drawer-mask" data-drawer-mask aria-hidden="true"></div>
