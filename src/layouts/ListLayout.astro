---
/**
 * ListLayout.astro — Post list page layout (home, taxonomy, archive).
 *
 * Wraps BaseLayout and renders the diary index.html structure:
 *   .post-list-container.post-list-container-no-background
 *     PostCard  × N
 *
 * Pagination state is forwarded to BaseLayout, which routes it to ExtraBar
 * (desktop) and Footer (mobile) for the actual paginator controls. The mobile
 * paginator deliberately lives in Footer — OUTSIDE .stream-container — so it
 * is not a following sibling of .post-list-container (which would make the
 * list's last card render a stray divider; see journal.scss).
 *
 * Props:
 *   title       — page <title> (optional; defaults to site title on home)
 *   description — meta description
 *   isHome      — true on the home page (title = siteTitle only)
 *   posts       — array of post card data to render
 *   page        — current page number (1-based)
 *   totalPages  — total number of pages
 *   prevUrl     — href for previous page (undefined on first page)
 *   nextUrl     — href for next page (undefined on last page)
 */

import BaseLayout from './BaseLayout.astro';
import PostCard, { type MetaOptions } from '../components/PostCard.astro';

interface PostCardData {
  href: string;
  title: string;
  summary?: string;
  featuredImage?: string | null;
  date: Date;
  categories?: string[];
  tags?: string[];
  readingSeconds?: number;
  draft?: boolean;
}

interface Props {
  title?: string;
  description?: string;
  isHome?: boolean;
  posts: PostCardData[];
  page?: number;
  totalPages?: number;
  prevUrl?: string;
  nextUrl?: string;
  /**
   * Override the per-card meta row. Defaults (set in PostMeta) already give the
   * list the desired "date · reading time" look with tags/categories hidden;
   * pass overrides to, e.g., re-enable tags on a specific list page.
   */
  metaOptions?: MetaOptions;
}

const {
  title,
  description,
  isHome = false,
  posts,
  page = 1,
  totalPages = 1,
  prevUrl,
  nextUrl,
  metaOptions,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  isHome={isHome}
  page={page}
  totalPages={totalPages}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
>
  <div class="post-list-container post-list-container-no-background">
    {posts.map((post) => (
      <PostCard
        href={post.href}
        title={post.title}
        summary={post.summary}
        featuredImage={post.featuredImage}
        date={post.date}
        categories={post.categories}
        tags={post.tags}
        readingSeconds={post.readingSeconds}
        draft={post.draft}
        metaOptions={metaOptions}
      />
    ))}
  </div>
</BaseLayout>
