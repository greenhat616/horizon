# ─────────────────────────────────────────────────────────────────────────────
# Public site configuration — validated by astro:env (context:client, access:public).
# These values are INLINED into the static build and are publicly visible:
# never put secrets here. For local builds:  cp .env.example .env
# In CI they are injected from GitHub repository Variables
# (Settings → Secrets and variables → Actions → Variables).
# ─────────────────────────────────────────────────────────────────────────────

# Canonical site origin. Drives <link rel="canonical">, the sitemap and RSS
# absolute URLs (astro.config `site:` + site.config `SITE_URL`).
PUBLIC_SITE_URL=https://i.a632079.me

# Artalk comment-server origin (the backend that stores and serves comments).
PUBLIC_ARTALK_SERVER=https://comments.a632079.me
