# Hugo build output — ignored; Astro's source public/ dir is tracked
# (Hugo writes its output to public/ only when running `hugo`; Astro uses dist/)
resources/_gen/
.hugo_build.lock

# Common dev artefacts
node_modules/
dist/
tmp/
.DS_Store

# Astro cache
.astro/

# Environment variables — local only; .env.example is the committed template
.env
.env.*
!.env.example

# Local tooling artefacts (not part of the source tree)
.serena/
.ccg/**/.turns.json
